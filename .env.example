# Environment Variables

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/setup

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/waawy_hrms?schema=public"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Loops.so)
LOOPS_API_KEY=your_loops_api_key_here
LOOPS_WAITLIST_TRANSACTIONAL_ID=your_waitlist_template_id
LOOPS_INVITE_TRANSACTIONAL_ID=your_invite_template_id
